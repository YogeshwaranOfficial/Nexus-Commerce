# ─── API ──────────────────────────────────────────────────
# For development (proxied via vite) — leave empty or use /api
VITE_API_URL=

# For production (full URL of your deployed backend)
# VITE_API_URL=https://api.your-nexus-domain.com/api

# ─── Razorpay (public key only — never use secret here) ───
VITE_RAZORPAY_KEY_ID=rzp_test_...

# ─── App ──────────────────────────────────────────────────
VITE_APP_NAME=Nexus Commerce
VITE_APP_URL=http://localhost:5173
